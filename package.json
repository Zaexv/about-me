    "threejs",
    "shader",
    "3d"
  ],
  "author": "Eduardo Pertierra Puche",
  "license": "MIT",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^9.39.4",
    "http-server": "^14.1.1",
    "live-server": "^1.2.2",
    "typescript": "^6.0.3"
  }
}
